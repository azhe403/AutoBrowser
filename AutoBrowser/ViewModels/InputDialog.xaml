<Window x:Class="AutoBrowser.ViewModels.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Input" Height="160" Width="450"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock x:Name="PromptText" Grid.Row="0" Margin="0,0,0,8"/>
        <TextBox x:Name="InputBox" Grid.Row="1" Margin="0,0,0,8" Text="https://"/>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" IsDefault="True" Width="80" Margin="0,0,8,0" Click="Ok_Click"/>
            <Button Content="Cancel" IsCancel="True" Width="80" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
