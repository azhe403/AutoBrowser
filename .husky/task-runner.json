{
  "$schema": "https://alirezanet.github.io/Husky.Net/schema.json",
  "tasks": [
    {
      "name": "Run unit tests",
      "group": "pre-commit",
      "command": "dotnet",
      "args": [
        "test",
        "src/AutoBrowser.Tests/AutoBrowser.Tests.csproj",
        "--filter",
        "FullyQualifiedName!~UI",
        "--verbosity",
        "quiet"
      ],
      "output": "always"
    },
    {
      "name": "Run all tests",
      "group": "pre-push",
      "command": "dotnet",
      "args": [
        "test",
        "src/AutoBrowser.Tests/AutoBrowser.Tests.csproj",
        "--verbosity",
        "quiet"
      ],
      "output": "always"
    }
  ]
}
