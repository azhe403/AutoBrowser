<UserControl x:Class="AutoBrowser.Views.FooterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Border Padding="8,4"
            Background="{DynamicResource CardBackgroundBrush}"
            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
            BorderThickness="1" CornerRadius="4">
        <DockPanel>
            <!-- Tray settings (right) -->
            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <TextBlock Text="Minimize to tray"
                           VerticalAlignment="Center"
                           Margin="0,0,4,0"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                <ui:ToggleSwitch IsChecked="{Binding MinimizeToTray}"
                                 VerticalAlignment="Center"
                                 Margin="0,0,12,0"/>

                <TextBlock Text="Close to tray"
                           VerticalAlignment="Center"
                           Margin="0,0,4,0"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                <ui:ToggleSwitch IsChecked="{Binding CloseToTray}"
                                 VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Fallback browser (left) -->
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center">
                <TextBlock Text="Fallback browser:"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                <ComboBox ItemsSource="{Binding AvailableBrowsers}"
                          SelectedItem="{Binding FallbackBrowser}"
                          DisplayMemberPath="DisplayName"
                          Width="250"
                          HorizontalAlignment="Left"/>
            </StackPanel>
        </DockPanel>
    </Border>
</UserControl>
