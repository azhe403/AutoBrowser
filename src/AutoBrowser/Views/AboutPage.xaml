<Page x:Class="AutoBrowser.Views.AboutPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:views="clr-namespace:AutoBrowser.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="About">

    <Grid Margin="24,24,24,60">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

            <!-- Column 0: Globe / App Icon -->
            <Grid Grid.Column="0" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,12,0,0">
                <Ellipse Width="72" Height="72" Fill="{DynamicResource ControlFillColorDefaultBrush}">
                    <Ellipse.Effect>
                        <DropShadowEffect BlurRadius="12" ShadowDepth="1" Opacity="0.1"/>
                    </Ellipse.Effect>
                </Ellipse>
                <ui:SymbolIcon Symbol="Globe24" Filled="True" FontSize="44" Foreground="{DynamicResource SystemAccentColorBrush}"/>
            </Grid>

            <!-- Column 1: Info -->
            <StackPanel Grid.Column="1" VerticalAlignment="Top" Margin="12,0,0,0">
                <TextBlock Text="AutoBrowser" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                <TextBlock Text="{Binding AppVersion, StringFormat='Version {0}'}" FontSize="13" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,2,0,16"/>
                
                <TextBlock Text="A lightweight URL interceptor and router for Windows that directs clicks to different web browsers based on matching rules." 
                           FontSize="14" TextWrapping="Wrap" LineHeight="20" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,24" MaxWidth="500" HorizontalAlignment="Left"/>
                
                <TextBlock FontSize="13" Margin="0,0,0,24">
                    <Run Text="Project Link: " Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    <Hyperlink Command="{Binding OpenUrlCommand}"
                               CommandParameter="https://github.com/azhe403/AutoBrowser">
                        github.com/azhe403/AutoBrowser
                    </Hyperlink>
                </TextBlock>

                <TextBlock Text="Third-Party Libraries &amp; Credits" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,16"/>

                <StackPanel MaxWidth="600" HorizontalAlignment="Left">
                    <!-- WPF-UI -->
                    <Border Padding="12,10" Margin="0,0,0,8" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1" CornerRadius="6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Grid.Column="0" Symbol="Library24" FontSize="20" Foreground="{DynamicResource SystemAccentColorBrush}" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Text="WPF-UI (v4.3.0)" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                <TextBlock Text="Provides modern Fluent Design System components and theme support for WPF applications." FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- CommunityToolkit.Mvvm -->
                    <Border Padding="12,10" Margin="0,0,0,8" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1" CornerRadius="6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Grid.Column="0" Symbol="Box24" FontSize="20" Foreground="{DynamicResource SystemAccentColorBrush}" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Text="CommunityToolkit.Mvvm (v8.4.2)" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                <TextBlock Text="A modern, fast, and modular MVVM library featuring C# source generators to simplify property changes and command bindings." FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Serilog -->
                    <Border Padding="12,10" Margin="0,0,0,8" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1" CornerRadius="6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Grid.Column="0" Symbol="DocumentBulletList24" FontSize="20" Foreground="{DynamicResource SystemAccentColorBrush}" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Text="Serilog (v4.4.0) &amp; Sinks" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                <TextBlock Text="A diagnostic logging library providing structured logging support, Console writing, and file output rolling." FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- DependencyInjection -->
                    <Border Padding="12,10" Margin="0,0,0,8" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1" CornerRadius="6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Grid.Column="0" Symbol="Connected24" FontSize="20" Foreground="{DynamicResource SystemAccentColorBrush}" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Text="Microsoft.Extensions.DependencyInjection (v10.0.9)" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                <TextBlock Text="The standard abstraction and implementation of the dependency injection pattern in .NET." FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Grid>
</Page>
