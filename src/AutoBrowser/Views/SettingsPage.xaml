<Page x:Class="AutoBrowser.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:views="clr-namespace:AutoBrowser.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Settings"
      Background="Transparent">

    <Grid Background="Transparent" Margin="0,0,0,60">
        <StackPanel Margin="24" MaxWidth="700" HorizontalAlignment="Left">
                <!-- Page Title -->
                <TextBlock Text="Settings" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,24"/>

                <!-- SECTION: Appearance -->
                <TextBlock Text="Appearance" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,12"/>
                <Border Padding="16,12" Margin="0,0,0,24" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1" CornerRadius="6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="App Theme" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <TextBlock Text="Change the appearance mode of the application" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding IsDarkTheme}" OffContent="Light" OnContent="Dark" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>

                <!-- SECTION: System Integration -->
                <TextBlock Text="System Integration" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,12"/>
                <StackPanel Margin="0,0,0,24">
                    <!-- Default Browser -->
                    <Border Padding="16,12" Margin="0,0,0,8" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1" CornerRadius="6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                                <TextBlock Text="Register as Default Web Browser" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                <TextBlock Text="Sets AutoBrowser as the default browser for standard HTTP/HTTPS links." FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" IsChecked="{Binding IsDefaultBrowser}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>

                    <!-- Protocol Handler -->
                    <Border Padding="16,12" Margin="0,0,0,8" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1" CornerRadius="6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                                <TextBlock Text="Register 'autobrowser://' Protocol" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                <TextBlock Text="Enables routing links containing the custom protocol scheme." FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" IsChecked="{Binding IsProtocolRegistered}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- SECTION: Routing & Fallback -->
                <TextBlock Text="Browser Routing" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,12"/>
                <Border Padding="16,12" Margin="0,0,0,24" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1" CornerRadius="6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                            <TextBlock Text="Fallback Web Browser" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <TextBlock Text="The browser that will open if no specific routing rules match." FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                        </StackPanel>
                        <ComboBox Grid.Column="1" ItemsSource="{Binding AvailableBrowsers}"
                                  SelectedItem="{Binding FallbackBrowser}"
                                  DisplayMemberPath="DisplayName"
                                  Width="250" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>

                <!-- SECTION: Window & System Tray -->
                <TextBlock Text="Window &amp; System Tray" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,12"/>
                <StackPanel Margin="0,0,0,16">
                    <!-- Minimize to Tray -->
                    <Border Padding="16,12" Margin="0,0,0,8" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1" CornerRadius="6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Minimize to System Tray" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                <TextBlock Text="Hides the main window to the system tray area when minimized" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                            <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding MinimizeToTray}" OffContent="Off" OnContent="On" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>

                    <!-- Close to Tray -->
                    <Border Padding="16,12" Margin="0,0,0,8" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1" CornerRadius="6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Close to System Tray" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                <TextBlock Text="Keeps the app running in the system tray instead of exiting on window close" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                            <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding CloseToTray}" OffContent="Off" OnContent="On" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Grid>
</Page>
