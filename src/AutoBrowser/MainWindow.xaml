<ui:FluentWindow x:Class="AutoBrowser.MainWindow"
                xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                mc:Ignorable="d"
                Title="AutoBrowser - URL Router" Icon="/app.ico" Height="650" Width="950"
                MinWidth="600" MinHeight="400"
                ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
                ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                ExtendsContentIntoTitleBar="True"
                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                WindowBackdropType="Mica"
                WindowCornerPreference="Round"
                WindowStartupLocation="CenterScreen"
                StateChanged="Window_StateChanged">
    <ui:FluentWindow.Resources>
    </ui:FluentWindow.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="AutoBrowser - URL Router" Icon="/app.ico"/>

        <Grid Grid.Row="1" Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Toolbar -->
            <Border Grid.Row="0" Margin="0,0,0,4" Padding="6,3"
                    Background="{DynamicResource CardBackgroundBrush}"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    BorderThickness="1" CornerRadius="4">
                <DockPanel>
                    <!-- Right-aligned: Check Update -->
                    <ui:Button Content="Check Update" Command="{Binding CheckForUpdateCommand}"
                               IsEnabled="{Binding CanCheckForUpdate}" DockPanel.Dock="Right"/>

                    <!-- Left-aligned groups -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Rule management -->
                        <ui:Button Content="Add" Command="{Binding AddRuleCommand}" Margin="0,0,3,0"/>
                        <ui:Button Content="Edit" Command="{Binding EditRuleCommand}" Margin="3,0"/>
                        <ui:Button Content="Delete" Command="{Binding DeleteRuleCommand}" Margin="3,0,0,0"/>

                        <Rectangle Width="1" Height="20" Fill="{DynamicResource ControlElevationBorderBrush}" Margin="6,0"/>

                        <!-- Rule ordering -->
                        <ui:Button Content="Move Up" Command="{Binding MoveUpCommand}" Margin="0,0,3,0"/>
                        <ui:Button Content="Move Down" Command="{Binding MoveDownCommand}"/>

                        <Rectangle Width="1" Height="20" Fill="{DynamicResource ControlElevationBorderBrush}" Margin="6,0"/>

                        <!-- Settings -->
                        <TextBlock Text="{Binding ThemeLabel}" Margin="0,0,2,0" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        <ui:ToggleSwitch IsChecked="{Binding IsDarkTheme}"
                                         VerticalAlignment="Center"/>

                        <Rectangle Width="1" Height="20" Fill="{DynamicResource ControlElevationBorderBrush}" Margin="6,0"/>

                        <!-- Tools -->
                        <ui:Button Content="Test URL" Command="{Binding LaunchUrlCommand}"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Rule list -->
            <ui:ListView x:Name="RuleListView" Grid.Row="1"
                         ItemsSource="{Binding Rules}"
                         SelectedItem="{Binding SelectedRule}"
                         SelectionMode="Single"
                         MouseDoubleClick="RuleListView_MouseDoubleClick">
                <ui:ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="10,8" Margin="0,2"
                                Background="{DynamicResource CardBackgroundBrush}"
                                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                BorderThickness="1" CornerRadius="6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <CheckBox Grid.Column="0" IsChecked="{Binding IsEnabled}"
                                          Checked="CheckBox_Toggled" Unchecked="CheckBox_Toggled"
                                          VerticalAlignment="Top" Margin="0,2,10,0"/>

                                <StackPanel Grid.Column="1">
                                    <!-- Row 1: Rule name + browser -->
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                        <TextBlock Text="  —  " Opacity="0.4"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                        <TextBlock Text="{Binding BrowserDisplayName}" Opacity="0.7"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                        <TextBlock Text="  —  " Opacity="0.4"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                        <TextBlock Text="{Binding BrowserPath}" Opacity="0.4"
                                                   TextTrimming="CharacterEllipsis"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                    </StackPanel>

                                    <!-- Row 2: Sequence + pattern -->
                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                        <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                CornerRadius="3" Padding="5,1" Margin="0,0,6,0">
                                            <TextBlock Text="{Binding Sequence, StringFormat='#{0}'}" FontSize="11"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                        </Border>
                                        <TextBlock Text="{Binding UrlPattern}" FontFamily="Consolas" FontSize="12"
                                                   TextTrimming="CharacterEllipsis"
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ui:ListView.ItemTemplate>
            </ui:ListView>

            <!-- Bottom-right registration checkboxes -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,4,0,0">
                <CheckBox Content="autobrowser://" IsChecked="{Binding IsProtocolRegistered}"
                          Margin="0,0,12,0" VerticalAlignment="Center"
                          Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                <CheckBox Content="Default browser" IsChecked="{Binding IsDefaultBrowser}"
                          VerticalAlignment="Center"
                          Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
            </StackPanel>
        </Grid>

        <!-- Fallback browser -->
        <Border Grid.Row="2" Margin="8,0,8,4" Padding="8,4"
                Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="1" CornerRadius="4">
            <DockPanel>
                <!-- Tray settings (right) -->
                <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                    <TextBlock Text="Minimize to tray"
                            VerticalAlignment="Center"
                            Margin="0,0,4,0"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                    <ui:ToggleSwitch IsChecked="{Binding MinimizeToTray}"
                                     VerticalAlignment="Center"
                            Margin="0,0,12,0"/>

                    <TextBlock Text="Close to tray"
                            VerticalAlignment="Center"
                            Margin="0,0,4,0"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                    <ui:ToggleSwitch IsChecked="{Binding CloseToTray}"
                                     VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Fallback browser (left) -->
                <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center">
                    <TextBlock Text="Fallback browser:"
                            VerticalAlignment="Center"
                            Margin="0,0,8,0"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                    <ComboBox ItemsSource="{Binding AvailableBrowsers}"
                              SelectedItem="{Binding FallbackBrowser}"
                              DisplayMemberPath="DisplayName"
                              Width="250"
                            HorizontalAlignment="Left"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Status bar -->
        <Border Grid.Row="3" Margin="8,0,8,8" Padding="8,4"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="1" CornerRadius="4">
            <TextBlock Text="{Binding Status}"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
        </Border>
    </Grid>
</ui:FluentWindow>
