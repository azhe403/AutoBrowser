<ui:FluentWindow x:Class="AutoBrowser.MainWindow"
                xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                mc:Ignorable="d"
                Title="AutoBrowser - URL Router" Icon="/app.ico" Height="650" Width="950"
                MinWidth="600" MinHeight="400"
                ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
                ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                ExtendsContentIntoTitleBar="True"
                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                WindowBackdropType="Mica"
                WindowCornerPreference="Round"
                WindowStartupLocation="CenterScreen"
                StateChanged="Window_StateChanged">
    <ui:FluentWindow.Resources>
    </ui:FluentWindow.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="AutoBrowser - URL Router" Icon="/app.ico"/>

        <Grid Grid.Row="1" Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Toolbar -->
            <Border Grid.Row="0" Margin="0,0,0,4" Padding="4,2"
                    Background="{DynamicResource CardBackgroundBrush}"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    BorderThickness="1" CornerRadius="4">
                <WrapPanel>
                <ui:Button Content="Add Rule" Command="{Binding AddRuleCommand}" Margin="0,0,4,4"/>
                <ui:Button Content="Edit Rule" Command="{Binding EditRuleCommand}" Margin="0,0,4,4"/>
                <ui:Button Content="Delete Rule" Command="{Binding DeleteRuleCommand}" Margin="0,0,4,4"/>
                <Rectangle Width="1" Fill="{DynamicResource ControlElevationBorderBrush}" Margin="4,2"/>
                <ui:Button Content="Move Up" Command="{Binding MoveUpCommand}" Margin="0,0,4,4"/>
                <ui:Button Content="Move Down" Command="{Binding MoveDownCommand}" Margin="0,0,4,4"/>
                <Rectangle Width="1" Fill="{DynamicResource ControlElevationBorderBrush}" Margin="4,2"/>
                <CheckBox Content="autobrowser:// protocol" IsChecked="{Binding IsProtocolRegistered}"
                          Margin="4,0" VerticalAlignment="Center"
                          Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                <CheckBox Content="Registered as default browser" IsChecked="{Binding IsDefaultBrowser}"
                          Margin="4,0" VerticalAlignment="Center"
                          Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                <Rectangle Width="1" Fill="{DynamicResource ControlElevationBorderBrush}" Margin="4,2"/>
                <TextBlock Text="Dark Mode:" Margin="4,0,0,0" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                <ui:ToggleSwitch IsChecked="{Binding IsDarkTheme}"
                                 Margin="2,0" VerticalAlignment="Center"/>
                <Rectangle Width="1" Fill="{DynamicResource ControlElevationBorderBrush}" Margin="4,2"/>
                <ui:Button Content="Test URL..." Command="{Binding LaunchUrlCommand}" Margin="0,0,4,4"/>
                <Rectangle Width="1" Fill="{DynamicResource ControlElevationBorderBrush}" Margin="4,2"/>
                <ui:Button Content="Check Update" Command="{Binding CheckForUpdateCommand}"
                           IsEnabled="{Binding CanCheckForUpdate}" Margin="0,0,4,4"/>
            </WrapPanel>
            </Border>

            <!-- Rule list -->
            <ui:ListView x:Name="RuleListView" Grid.Row="1"
                         ItemsSource="{Binding Rules}"
                         SelectedItem="{Binding SelectedRule}"
                         SelectionMode="Single"
                         MouseDoubleClick="RuleListView_MouseDoubleClick">
                <ui:ListView.View>
                    <ui:GridView>
                        <ui:GridViewColumn Header="Enabled" Width="60">
                            <ui:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsEnabled}" Checked="CheckBox_Toggled" Unchecked="CheckBox_Toggled"
                                              Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                </DataTemplate>
                            </ui:GridViewColumn.CellTemplate>
                        </ui:GridViewColumn>
                        <ui:GridViewColumn Header="Priority" Width="60"
                                           DisplayMemberBinding="{Binding Priority}"/>
                        <ui:GridViewColumn Header="Name" Width="200"
                                           DisplayMemberBinding="{Binding Name}"/>
                        <ui:GridViewColumn Header="URL Pattern" Width="250"
                                           DisplayMemberBinding="{Binding UrlPattern}"/>
                        <ui:GridViewColumn Header="Browser" Width="250"
                                           DisplayMemberBinding="{Binding BrowserPath}"/>
                    </ui:GridView>
                </ui:ListView.View>
            </ui:ListView>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="2" Margin="8,0,8,8" Padding="8,4"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="1" CornerRadius="4">
            <TextBlock Text="{Binding Status}"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
        </Border>
    </Grid>
</ui:FluentWindow>
